# Configure msmtp https://marlam.de/msmtp/msmtp.html
# Delete this file when mail sending is not needed

# Set default values
defaults
tls             on
tls_starttls    off
set_from_header on
allow_from_override off
logfile         -

account        default_account
host           smtp.example.com
port           465
from           noreply@example.com
auth           on
user           noreply@example.com
password       PASSWORD

# Set a default account
account default : default_account
